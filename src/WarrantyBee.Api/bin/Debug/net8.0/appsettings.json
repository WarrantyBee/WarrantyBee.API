{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "App": {
    "Name": "WarrantyBee API",
    "Environment": "Development",
    "IsCaptchaEnabled": true,
    "DataSource": {
      "ConnectionString": "Server=localhost;Database=WarrantyBee;Trusted_Connection=True;TrustServerCertificate=True;"
    },
    "Upstash": {
      "Host": "https://example-upstash.com",
      "AccessToken": "your-upstash-token"
    },
    "Jwt": {
      "Issuer": "WarrantyBee",
      "Audience": "WarrantyBeeClient",
      "Secret": "A-Very-Long-Secret-Key-With-At-Least-32-Characters",
      "Expiration": 60
    },
    "Smtp": {
      "Host": "smtp.gmail.com",
      "Port": 587,
      "Username": "your-email@gmail.com",
      "Password": "your-app-password"
    },
    "Otp": {
      "Expiration": 5
    }
  }
}
